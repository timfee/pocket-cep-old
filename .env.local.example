# =============================================================================
# Pocket CEP — .env.local
# =============================================================================
#
# Copy this file and fill in the blanks:
#
#   cp .env.local.example .env.local
#
# Anything you don't set here falls back to the committed defaults in `.env`.
# Only override what you need to.
# =============================================================================


# -----------------------------------------------------------------------------
# Secrets (required)
# -----------------------------------------------------------------------------

# BetterAuth session signing secret.
#   Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=

# LLM API key. Set the one that matches LLM_PROVIDER below.
#   Claude: https://console.anthropic.com/ → Settings → API Keys
#   Gemini: https://aistudio.google.com/app/apikey
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=


# -----------------------------------------------------------------------------
# Google OAuth (only needed when AUTH_MODE=user_oauth)
# -----------------------------------------------------------------------------
# console.cloud.google.com → APIs & Services → Credentials → OAuth client ID
# Add this redirect URI to the client:
#   http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# -----------------------------------------------------------------------------
# Optional overrides (defaults live in `.env`)
# -----------------------------------------------------------------------------

# AUTH_MODE:
#   service_account  — no user sign-in; MCP server uses ADC (default)
#   user_oauth       — user signs in; their token is forwarded to MCP
# AUTH_MODE=service_account

# LLM_PROVIDER:
#   claude  — Anthropic (requires ANTHROPIC_API_KEY)
#   gemini  — Google Generative AI (requires GOOGLE_AI_API_KEY)
# LLM_PROVIDER=claude

# LLM_MODEL: leave blank to use the default for the chosen provider.
# LLM_MODEL=

# MCP server URL. Start it with `npm run dev:full`.
# MCP_SERVER_URL=http://localhost:4000/mcp

# Canonical URL where Pocket CEP runs (used for OAuth callbacks).
# BETTER_AUTH_URL=http://localhost:3000
