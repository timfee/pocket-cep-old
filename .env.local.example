# =============================================================================
# Pocket CEP — Local Secrets (Example)
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.local.example .env.local
#
# See .env for non-secret configuration options (auth mode, MCP URL, etc.).
# =============================================================================

# BetterAuth session signing secret.
# Generate:  openssl rand -base64 32
BETTER_AUTH_SECRET=

# Google OAuth credentials (console.cloud.google.com → APIs & Services → Credentials)
# Redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LLM API keys — only the one matching LLM_PROVIDER in .env is required.
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
