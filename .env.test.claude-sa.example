# Pocket CEP -- Test Flavor: Claude + Service Account
#
# Use this flavor when:
#   - You want the simplest possible setup (no Google OAuth credentials needed)
#   - The MCP server machine already has Application Default Credentials (ADC)
#     configured (e.g., via `gcloud auth application-default login`)
#   - You want to test the Claude LLM provider
#
# How it works:
#   - AUTH_MODE=service_account skips Google OAuth entirely. The app auto-creates
#     an anonymous session via BetterAuth's anonymous plugin.
#   - The MCP server uses its own ADC to call Google APIs, so no user token is
#     forwarded.
#   - LLM_PROVIDER=claude routes chat requests through the Anthropic API.
#
# Copy to .env.test.claude-sa and fill in values:
#   cp .env.test.claude-sa.example .env.test.claude-sa


# Auth mode: "service_account" means no Google OAuth login is needed.
# The app mints an anonymous session automatically.
AUTH_MODE=service_account

# LLM provider: "claude" uses the Anthropic API.
LLM_PROVIDER=claude

# Anthropic API key.
# Get one at: https://console.anthropic.com/
#   1. Sign in or create an account
#   2. Go to Settings > API Keys
#   3. Click "Create Key" and copy the value
ANTHROPIC_API_KEY=

# BetterAuth session signing secret.
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# URL where Pocket CEP is running. Used by BetterAuth for callback URLs.
BETTER_AUTH_URL=http://localhost:3000

# URL of the Chrome Enterprise Premium MCP server in HTTP mode.
# Start it with: npm run dev:full
# Or manually:   GCP_STDIO=false PORT=4000 npx @google/chrome-enterprise-premium-mcp@latest
MCP_SERVER_URL=http://localhost:4000/mcp

# Optional: override the default Claude model (claude-sonnet-4-20250514).
LLM_MODEL=

# Not needed in this flavor (service_account mode).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Not needed in this flavor (Claude provider).
GOOGLE_AI_API_KEY=
