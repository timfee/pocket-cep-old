# Pocket CEP -- Test Flavor: Claude + User OAuth
#
# Use this flavor when:
#   - You want to test the full Google OAuth sign-in flow
#   - The signed-in user's Google access token should be forwarded to the
#     MCP server (the user must be a Workspace admin with the right scopes)
#   - You want to test the Claude LLM provider
#
# How it works:
#   - AUTH_MODE=user_oauth shows the Google sign-in button on the landing page.
#   - After sign-in, BetterAuth stores the user's Google OAuth tokens and
#     forwards them as a Bearer header to the MCP server on every tool call.
#   - LLM_PROVIDER=claude routes chat requests through the Anthropic API.
#
# Copy to .env.test.claude-oauth and fill in values:
#   cp .env.test.claude-oauth.example .env.test.claude-oauth


# Auth mode: "user_oauth" requires Google OAuth sign-in.
# The user's access token is forwarded to the MCP server.
AUTH_MODE=user_oauth

# LLM provider: "claude" uses the Anthropic API.
LLM_PROVIDER=claude

# Anthropic API key.
# Get one at: https://console.anthropic.com/
#   1. Sign in or create an account
#   2. Go to Settings > API Keys
#   3. Click "Create Key" and copy the value
ANTHROPIC_API_KEY=

# Google OAuth credentials.
# Get these at: https://console.cloud.google.com/apis/credentials
#   1. Create or select a project
#   2. Click "Create Credentials" > "OAuth client ID"
#   3. Application type: "Web application"
#   4. Add authorized redirect URI: http://localhost:3000/api/auth/callback/google
#   5. Copy the Client ID and Client Secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# BetterAuth session signing secret.
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# URL where Pocket CEP is running. Used by BetterAuth for callback URLs.
BETTER_AUTH_URL=http://localhost:3000

# URL of the Chrome Enterprise Premium MCP server in HTTP mode.
# Start it with: npm run dev:full
# Or manually:   GCP_STDIO=false PORT=4000 npx @google/chrome-enterprise-premium-mcp@latest
MCP_SERVER_URL=http://localhost:4000/mcp

# Optional: override the default Claude model (claude-sonnet-4-20250514).
LLM_MODEL=

# Not needed in this flavor (Claude provider).
GOOGLE_AI_API_KEY=
