# Pocket CEP — Default Configuration
#
# This file is committed to source control. It contains non-secret defaults
# and serves as documentation for every configuration option.
#
# Secrets go in .env.local (gitignored). Values in .env.local override these.


# Auth Mode
# Controls how the app authenticates with the Chrome Enterprise Premium MCP
# server. Two modes are available:
#
#   "service_account" — The MCP server uses Application Default Credentials
#     (ADC) from the machine it runs on. The user signs into Pocket CEP with
#     basic Google OAuth (openid, email, profile) just to access the UI.
#     Simpler to set up; good for demos where the server already has ADC.
#
#   "user_oauth" — The user signs in with the full set of Google Admin scopes.
#     Their personal OAuth access token is forwarded as a Bearer token to the
#     MCP server, which uses it for every Google API call. This means the user
#     must be a Google Workspace admin with the right permissions.
#
AUTH_MODE=service_account



# MCP Server
# URL of the Chrome Enterprise Premium MCP server running in HTTP mode.
MCP_SERVER_URL=http://localhost:4000/mcp

# MCP Server Auto-Start (optional)
# If set, Pocket CEP will spawn the MCP server as a child process on startup.
# Leave blank to manage the MCP server yourself in a separate terminal.
#
# Examples:
#   Published package (no local clone needed):
#     MCP_SERVER_CMD=npx @google/chrome-enterprise-premium-mcp@latest
#
#   Local clone:
#     MCP_SERVER_CMD=node ../cmcp/mcp-server.js
#
# The command runs with GCP_STDIO=false injected automatically.
# The server's stdout/stderr are piped to Pocket CEP's console with a [mcp-server] prefix.
# The process is killed when Pocket CEP shuts down.
#
MCP_SERVER_CMD=



# LLM Provider
# Which large language model powers the chat agent.
#
#   "claude"  — Uses the Anthropic API (@anthropic-ai/sdk).
#               Requires ANTHROPIC_API_KEY in .env.local.
#
#   "gemini"  — Uses the Google Generative AI API (@google/generative-ai).
#               Requires GOOGLE_AI_API_KEY in .env.local.
#
LLM_PROVIDER=claude



# LLM Model (optional override)
# Specific model ID to use. If blank, sensible defaults are chosen:
#   Claude  → claude-sonnet-4-20250514
#   Gemini  → gemini-2.0-flash
#
LLM_MODEL=



# App URL
# The canonical URL where Pocket CEP is running. BetterAuth uses this to
# build callback URLs for OAuth redirects.
#
BETTER_AUTH_URL=http://localhost:3000
